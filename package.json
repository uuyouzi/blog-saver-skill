    "start": "node src/index.cjs",
    "test": "node src/index.cjs --help",
    "postinstall": "echo '[blog-saver] Please run: npx playwright install chromium'"
  },
  "keywords": [
    "scraper",
    "wechat",
    "article",
    "html",
    "markdown",
    "playwright",
